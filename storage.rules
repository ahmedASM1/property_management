rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read/write for authenticated users
      allow read, write: if request.auth != null;
      
      // Admin has full access
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isTenant() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tenant';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isApproved() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isAdmin() || isOwner(userId));
      allow create: if isAuthenticated(); // allow new user doc creation at signup
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // Admin notifications collection
    match /admin_notifications/{notificationId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // User notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid
      );
      allow create: if isAdmin();
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Contracts collection
    match /contracts/{contractId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        (isTenant() && resource.data.tenantId == request.auth.uid)
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();

      // Contract comments subcollection
      match /comments/{commentId} {
        allow read: if isAuthenticated() && (
          isAdmin() || 
          (isTenant() && resource.data.tenantId == request.auth.uid)
        );
        allow create: if isAuthenticated() && (
          isAdmin() || 
          (isTenant() && resource.data.tenantId == request.auth.uid)
        );
        allow update, delete: if isAdmin();
      }
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        (isTenant() && resource.data.tenantId == request.auth.uid)
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.fromId == request.auth.uid);
    }

    // Maintenance Requests collection
    match /maintenance_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Properties collection
    match /properties/{propertyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Units collection
    match /units/{unitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Fallback rule for any other collections - allow authenticated users basic access
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}